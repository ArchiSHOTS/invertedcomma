# ── Required ──────────────────────────────────────────────────────────────────

# Neon PostgreSQL — production branch connection string
# Neon dashboard → your project → Branches → main → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# JWT signing secret — generate with: openssl rand -base64 48
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# ── Google Sign-In (optional — email/password works without these) ───────────
# Create an OAuth 2.0 Client ID (Web application) at:
#   https://console.cloud.google.com/apis/credentials
# Both must be the SAME client ID. VITE_ is baked into the frontend at build time;
# the server one is used to verify the audience of incoming Google tokens.
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
VITE_GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"

# ── Set automatically by Render — do not add these manually ──────────────────
# NODE_ENV=production
# PORT=10000
